# Build
TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu

# Docker Compose publishes service ports with daemon-assigned host ports by default.
# Discover them after startup with:
#   docker compose port web 8080
#   docker compose port inference 8000
#   docker compose port mlflow 5000
#   docker compose port prometheus 9090
#   docker compose port grafana 3000

# Optional public URLs shown in the browser UI. Leave blank for daemon-assigned ports.
# On a VM, set these only after choosing fixed ports or after deploying behind a reverse proxy.
LOG_MONITOR_PUBLIC_WEB_URL=
LOG_MONITOR_PUBLIC_INFERENCE_URL=
LOG_MONITOR_PUBLIC_MLFLOW_URL=
LOG_MONITOR_PUBLIC_PROMETHEUS_URL=
LOG_MONITOR_PUBLIC_GRAFANA_URL=

# Azure defaults used by the app services
AZURE_RESOURCE_GROUP=LogClassifier-RG
AZURE_WORKSPACE_NAME=LogClassifier-Workspace

# Optional secrets. Prefer injecting these from your deployment platform in production.
OPENAI_API_KEY=
GITHUB_TOKEN=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
